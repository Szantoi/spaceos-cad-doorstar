# ── Embedding backend ────────────────────────────────────────────────────────
# Default: local all-MiniLM-L6-v2 (no API key needed, model downloads ~25MB on first run)
# Optional upgrade: set VOYAGE_API_KEY for voyage-3-lite (better semantic quality)
# Get key from: https://dash.voyageai.com/  (free tier available)
# VOYAGE_API_KEY=your_voyage_key_here

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Start with: docker compose up -d
CHROMA_URL=http://localhost:8001

# ── Paths (REQUIRED - set these to your installation) ─────────────────────────
# Where the knowledge-service is installed
# SERVICE_ROOT=/path/to/knowledge-service

# Where terminals are located
TERMINALS_PATH=./terminals

# Where documentation/knowledge base is
# KNOWLEDGE_BASE_PATH=./docs/knowledge

# ── Server port ───────────────────────────────────────────────────────────────
PORT=3456

# ── Nightwatch Scheduler ───────────────────────────────────────────────────────
# TypeScript replacement for bash cron pipeline
# Set to 'true' to enable built-in scheduler
# ENABLE_NIGHTWATCH=true
# NIGHTWATCH_INTERVAL=120000

# ── Telegram (for notifications) ───────────────────────────────────────────────
# TELEGRAM_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# ── Autonomous Development ───────────────────────────────────────────────────────
# Enable autonomous development scheduler (cold-start Conductor every N minutes)
# ENABLE_AUTONOMOUS_DEV=true
# AUTONOMOUS_DEV_INTERVAL_MINUTES=20
# AUTONOMOUS_DEV_FOCUS_FILE=./docs/tasks/PROJECT_STATUS.md

# Token optimization (reduces prompt size by 30-50%)
# AUTONOMOUS_DEV_TOKEN_BUDGET=300
# AUTONOMOUS_DEV_INCLUDE_ARCHITECT_GUIDANCE=auto    # auto|always|never
# AUTONOMOUS_DEV_INCLUDE_MCP_EXAMPLES=first-3       # first-3|always|never
# AUTONOMOUS_DEV_INCLUDE_QUEUE_GUIDANCE=auto        # auto|always|never
# AUTONOMOUS_DEV_PROMPT_TEMPLATE=base               # base|verbose|minimal
